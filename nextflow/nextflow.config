/*
 * DupCaller Nextflow Pipeline Configuration
 */

// Global default params
params {

    // -----------------------------------------------------------------------
    // Pipeline control
    // -----------------------------------------------------------------------
    help          = false
    outdir        = "./results"
    skip_trim     = false           // skip barcode trimming (provide pre-trimmed FASTQs or BAM)
    skip_align    = false           // skip alignment (provide pre-aligned BAM)
    skip_normal   = false           // run without matched normal (set max_af accordingly)

    // -----------------------------------------------------------------------
    // Input files
    // -----------------------------------------------------------------------
    sample_name   = null            // sample name prefix for all output files (required)
    read1         = null            // tumor read 1 FASTQ (start from FASTQ)
    read2         = null            // tumor read 2 FASTQ (start from FASTQ)
    normal_read1  = null            // normal read 1 FASTQ
    normal_read2  = null            // normal read 2 FASTQ
    tumor_bam     = null            // pre-aligned/markdup tumor BAM (skip trim + align)
    normal_bam    = null            // pre-aligned normal BAM (must have .bai index)

    // -----------------------------------------------------------------------
    // Reference files
    // -----------------------------------------------------------------------
    reference     = null            // (-f) reference genome FASTA — must be indexed with
                                    //   DupCaller.py index (produces ref.h5, tn.h5, hp.h5)
    str_bed       = null            // (-s, index only) tabix-indexed STR BED file for indexing

    // -----------------------------------------------------------------------
    // Barcode trimming  (DupCaller.py trim)
    // -----------------------------------------------------------------------
    barcode_pattern = "NNNXXXX"     // (-p) barcode pattern: N = barcode base, X = skipped base
                                    //   NanoSeq default: 3-base barcode + 4 constant = NNNXXXX

    // -----------------------------------------------------------------------
    // Alignment  (bwa mem)
    // -----------------------------------------------------------------------
    threads         = 4             // (-t / -p) number of threads for alignment & variant calling
    platform        = "ILLUMINA"    // sequencing platform for read group (@RG PL tag)
    read_group_id   = null          // read group ID; defaults to sample_name when null

    // -----------------------------------------------------------------------
    // Variant calling — Required  (DupCaller.py call)
    // -----------------------------------------------------------------------
    // -b  bam        set via tumor_bam / pipeline routing
    // -f  reference  set above
    // -o  output     derived from sample_name

    // -----------------------------------------------------------------------
    // Variant calling — Recommended  (DupCaller.py call)
    // -----------------------------------------------------------------------
    regions         = "chr1 chr2 chr3 chr4 chr5 chr6 chr7 chr8 chr9 chr10 " +
                      "chr11 chr12 chr13 chr14 chr15 chr16 chr17 chr18 chr19 " +
                      "chr20 chr21 chr22 chrX chrY"
                                    // (-r) contigs for variant calling; adjust for non-human genomes
    germline_vcf    = null          // (-g) tabix-indexed germline VCF with AF field (e.g. gnomAD)
    normal_bam      = null          // (-n) matched normal BAM; when absent set max_af appropriately
    noise_mask      = null          // (-m) tabix-indexed BED file(s) masking noisy positions
    region_file     = null          // (-R) inclusive BED file restricting analysis to target regions
    max_af          = 1.0           // (-maf) maximum allele fraction; set ~0.1 when no normal
    trim_template   = 7             // (-tt) ignore mutations within N bp of template ends
    trim_read       = 7             // (-tr) ignore mutations within N bp of read ends

    // -----------------------------------------------------------------------
    // Variant calling — Optional  (DupCaller.py call)
    // -----------------------------------------------------------------------
    max_normal_af       = 0.01      // (--naf) maximum VAF in matched normal to call a mutation
    rescue              = false     // (--rescue) output discarded variants with reason in FILTER
    nm_filter           = 5         // (-nm / --nmflt) discard reads with edit distance > this value
    min_mean_asxs       = 50        // (-ax / --minMeanASXS) minimum mean AS-XS score for a read group
    germline_af_cutoff  = 0.001     // (-gaf / --germlineAfCutoff) skip positions with germline AF above this
    min_n_depth         = 10        // (-d / --minNdepth) minimum normal coverage for called variants

    // -----------------------------------------------------------------------
    // Variant calling — Advanced  (DupCaller.py call)
    // -----------------------------------------------------------------------
    amp_err_file        = null      // (-AS / --amperrfile) pre-learned amplification SBS error profile
    amp_err_file_indel  = null      // (-AI / --amperrfileindel) pre-learned amplification indel error profile
    dmg_err_file        = null      // (-DS / --dmgerrfile) pre-learned damage SBS error profile
    dmg_err_file_indel  = null      // (-DI / --dmgerrfileindel) pre-learned damage indel error profile
    mut_rate            = 2.5e-7    // (-mr / --mutRate) prior somatic mutation rate per base
    threshold_snv       = 0.5       // (-ts / --thresholdSnv) log-likelihood ratio threshold for SNV calls
    threshold_indel     = 0.5       // (-ti / --thresholdIndel) log-likelihood ratio threshold for indel calls
    mapq                = 40        // (-mq / --mapq) minimum mapping quality for an alignment
    window_size         = 100000    // (-w / --windowSize) genomic window size for coverage/region splitting
    min_bq              = 18        // (-bq / --minBq) bases below this quality are set to Q6
    min_alt_qual        = 60        // (-aq / --minAltQual) minimum consensus quality of alt allele in a read group
    min_ref_consensus   = 2         // (--minRef) minimum consensus quality of ref allele in a read group
    min_alt_consensus   = 2         // (--minAlt) minimum consensus quality of alt allele in a read group
    max_zero_qual_frac  = 0.5       // (-z / --maxZeroQualFrac) maximum fraction of zero-quality bases in a read family
    indel_bed           = null      // (-id / --indelBed) indel enhanced panel of normals (ePoN)

    // -----------------------------------------------------------------------
    // Burden estimation — Required  (DupCaller.py estimate)
    // -----------------------------------------------------------------------
    // -i  prefix     derived from sample_name

    // -----------------------------------------------------------------------
    // Burden estimation — Reference options  (choose one)
    // -----------------------------------------------------------------------
    // -f  reference  set above (shared with call command)
    ref_trinuc          = null      // (-ft / --refTrinuc) precomputed trinucleotide composition file
                                    //   (alternative to providing the full reference FASTA)

    // -----------------------------------------------------------------------
    // Burden estimation — Optional  (DupCaller.py estimate)
    // -----------------------------------------------------------------------
    // -r  regions    shared with call command (see above)
    out_trinuc          = null      // (-ot / --outTrinuc) save computed trinucleotide composition to this file
    estimate_clonal     = false     // (-c / --clonal) count multi-molecule mutations as one
    estimate_dilute     = false     // (-d / --dilute) sample and normal from same starting DNA material
    gene_bed            = null      // (-gb / --genebed) gene BED for per-gene duplex coverage (dNdScv)
    reestimate_bed      = null      // (-rb / --reestimatebed) re-estimate burden in these regions without re-calling

    // -----------------------------------------------------------------------
    // Resource limits (applied via check_max())
    // -----------------------------------------------------------------------
    max_memory = 128.GB
    max_cpus   = 16
    max_time   = 240.h
}

// Process resource requirements
process {
    // Default resources
    cpus = 1
    memory = 4.GB
    time = 4.h

    // Error handling
    errorStrategy = { task.exitStatus in [143,137,104,134,139] ? 'retry' : 'finish' }
    maxRetries = 3

    withName: INDEX_REFERENCE {
        cpus = 1
        memory = 8.GB
        time = 2.h
    }

    withName: TRIM_BARCODES {
        cpus = 1
        memory = 4.GB
        time = 4.h
    }

    withName: BWA_ALIGN {
        cpus = { check_max(8 * task.attempt, 'cpus') }
        memory = { check_max(16.GB * task.attempt, 'memory') }
        time = { check_max(8.h * task.attempt, 'time') }
    }

    withName: MARK_DUPLICATES {
        cpus = 1
        memory = { check_max(16.GB * task.attempt, 'memory') }
        time = { check_max(6.h * task.attempt, 'time') }
    }

    withName: CALL_VARIANTS {
        cpus = { check_max(params.threads * task.attempt, 'cpus') }
        memory = { check_max(32.GB * task.attempt, 'memory') }
        time = { check_max(24.h * task.attempt, 'time') }
    }

    withName: ESTIMATE_BURDEN {
        cpus = 1
        memory = { check_max(8.GB * task.attempt, 'memory') }
        time = { check_max(4.h * task.attempt, 'time') }
    }
}

// Execution profiles
profiles {
    standard {
        process.executor = 'local'
    }

    slurm {
        process {
            executor = 'slurm'
            queue = 'normal'
            clusterOptions = '--qos=normal'
        }
        executor {
            queueSize = 50
            submitRateLimit = '10 sec'
        }
    }

    sge {
        process {
            executor = 'sge'
            penv = 'smp'
        }
        executor {
            queueSize = 50
            submitRateLimit = '10 sec'
        }
    }

    pbs {
        process {
            executor = 'pbs'
        }
        executor {
            queueSize = 50
            submitRateLimit = '10 sec'
        }
    }

    docker {
        docker.enabled = true
        docker.userEmulation = true
        process.container = 'dupcaller:latest'
    }

    singularity {
        singularity.enabled = true
        singularity.autoMounts = true
        process.container = 'dupcaller.sif'
    }

    test {
        params {
            sample_name = 'test_sample'
            threads = 1
            max_memory = 8.GB
            max_cpus = 1
        }
    }
}

// Container settings
docker {
    enabled = false
    runOptions = '-u $(id -u):$(id -g)'
}

singularity {
    enabled = false
    autoMounts = true
}

// Manifest
manifest {
    name = 'DupCaller'
    author = 'DupCaller team'
    homePage = 'https://github.com/YuheCheng62/DupCaller'
    description = 'Pipeline for calling somatic mutations from error-corrected NGS data'
    mainScript = 'DupCaller.nf'
    nextflowVersion = '>=21.04.0'
    version = '1.1.0'
}

// Pipeline reporting
timeline {
    enabled = true
    overwrite = true
    file = "${params.outdir}/pipeline_info/execution_timeline.html"
}

report {
    enabled = true
    overwrite = true
    file = "${params.outdir}/pipeline_info/execution_report.html"
}

trace {
    enabled = true
    overwrite = true
    file = "${params.outdir}/pipeline_info/execution_trace.txt"
    fields = 'task_id,hash,native_id,process,tag,name,status,exit,module,container,cpus,time,disk,memory,attempt,submit,start,complete,duration,realtime,queue,%cpu,%mem,rss,vmem,peak_rss,peak_vmem,rchar,wchar,syscr,syscw,read_bytes,write_bytes'
}

dag {
    enabled = true
    overwrite = true
    file = "${params.outdir}/pipeline_info/pipeline_dag.svg"
}

// Function to ensure that resource requirements don't go beyond maximum limit
def check_max(obj, type) {
    if (type == 'memory') {
        try {
            if (obj.compareTo(params.max_memory as nextflow.util.MemoryUnit) == 1)
                return params.max_memory as nextflow.util.MemoryUnit
            else
                return obj
        } catch (all) {
            println "ERROR: invalid memory specified: $obj"
            return params.max_memory as nextflow.util.MemoryUnit
        }
    } else if (type == 'time') {
        try {
            if (obj.compareTo(params.max_time as nextflow.util.Duration) == 1)
                return params.max_time as nextflow.util.Duration
            else
                return obj
        } catch (all) {
            println "ERROR: invalid time specified: $obj"
            return params.max_time as nextflow.util.Duration
        }
    } else if (type == 'cpus') {
        try {
            return Math.min(obj as int, params.max_cpus as int)
        } catch (all) {
            println "ERROR: invalid cpus specified: $obj"
            return params.max_cpus as int
        }
    }
}
